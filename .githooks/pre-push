#!/usr/bin/env bash
# Run the test suite before pushing; abort the push if any test fails.
# Runs the repo-level specs plus every package's `rake test` in build order.
# Enabled via `rake hooks:install` (core.hooksPath=.githooks).
set -euo pipefail

# A push that only deletes remote refs has nothing to test; allow it.
only_deletes=1
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
    only_deletes=0
  fi
done
if [ "$only_deletes" -eq 1 ]; then
  exit 0
fi

root="$(git rev-parse --show-toplevel)"
cd "$root"

# `bundle` is preferred, but some rvm/rbenv setups ship a binstub whose shebang
# cannot locate ruby. Fall back to `ruby -S bundle`, which ignores the shebang.
if bundle --version >/dev/null 2>&1; then
  bundle_exec() { bundle exec "$@"; }
else
  bundle_exec() { ruby -S bundle exec "$@"; }
fi

echo "pre-push: running repository specs..."
if ! bundle_exec rake test; then
  echo "pre-push: repository specs failed; push aborted."
  exit 1
fi

echo "pre-push: running each package's tests (build order)..."
if ! bundle_exec rake 'monorepo:each[test]'; then
  echo "pre-push: package tests failed; push aborted."
  exit 1
fi

echo "pre-push: all tests passed."
exit 0
